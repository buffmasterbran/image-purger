# Copy to .env.local and fill in.

# === Prisma (required) ===
DATABASE_URL="postgres://postgres:YOUR_PASSWORD@YOUR_HOST:5436/postgres"

# === Ingest API (NetSuite / ingest-batch) ===
# API_KEY=
# API_SECRET=

# === ShipEngine (create-label, get-services) ===
# SHIPENGINE_API_KEY=

# === ShipStation (create-order) ===
# SHIPSTATION_API_KEY=
# SHIPSTATION_API_SECRET=

# === PrintNode (printers, scales) ===
# PRINT_NODE=

# === NetSuite REST API (Item Fulfillment push) ===
# NETSUITE_ACCOUNT_ID=
# NETSUITE_CONSUMER_KEY=
# NETSUITE_CONSUMER_SECRET=
# NETSUITE_TOKEN_ID=
# NETSUITE_TOKEN_SECRET=
# NETSUITE_REALM=

# === Session (JWT signing) ===
# Must be ≥32 characters. Used by API routes at runtime and by middleware (often baked in at `next build`).
# Docker/standalone: set this during the image build, not only when starting the container, or auth cookies will mismatch.
# SESSION_SECRET=your_32_character_secret_key_here
